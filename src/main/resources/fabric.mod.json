{
  "schemaVersion": 1,
  "id": "createdeco",
  "version": "${version}",
  "name": "Create Deco",
  "description": "Decorative options for your Create factory",
  "authors": [
    "Kayla",
    "Talrey",
    "Ordana",
    "Cassian"
  ],
  "contact": {
    "homepage": "https://github.com/talrey/CreateDeco",
    "sources": "https://github.com/talrey/CreateDeco",
    "issues": "https://github.com/talrey/CreateDeco/issues"
  },
  "license": "All Rights Reserved",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.github.talrey.createdeco.fabric.CreateDecoModFabric"
    ]
  },
  "mixins": [
    "createdeco-common.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.2",
    "fabric-api": "*",
    "minecraft": "${minecraft_version_range}",
    "create": "${create_version_range}"
